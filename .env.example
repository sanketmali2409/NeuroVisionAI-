# Copy this file to `.env` and fill in real values.
# Never commit the real `.env` file - it's gitignored.

# ---- General ----------------------------------------------------------
APP_NAME=NeuroVision AI
APP_ENV=development
DEBUG=true

# ---- Server -------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=8501
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# ---- Database -------------------------------------------------------------
DATABASE_URL=sqlite:///./neurovision.db

# ---- Auth / security ---------------------------------------------------------
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- LLM providers (optional; only needed for report generation + RAG) --------
OPENAI_API_KEY=
GEMINI_API_KEY=

# ---- Logging ------------------------------------------------------------------
LOG_LEVEL=INFO
